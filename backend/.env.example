# ── Database ────────────────────────────────────────────

PGUSER=postgres
PGHOST=localhost
PGDATABASE=fuebot_db
PGPASSWORD="11223345Aa#"
PGPORT=5432

# ── Session ─────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=fuechatbot_super_secret_key_2026_abcxyz

# ── Server ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────
# URL of your frontend app
CLIENT_URL=http://localhost:3000

# ── AI Service (Python FastAPI) ─────────────────────────
# URL of the Python RAG chatbot API (must be running separately)
AI_SERVICE_URL=http://localhost:8000
# Request timeout in milliseconds (increase for slow LLM responses)
AI_SERVICE_TIMEOUT=30000
# Set to false to disable AI and use keyword-based fallback only
AI_ENABLED=true
