# =====================================================
#  Academic Advisor Chatbot – Environment Variables
# =====================================================

# --- LLM: "google" | "huggingface" | "openrouter" ---
LLM_PROVIDER=google

# --- Google Gemini (recommended; set LLM_PROVIDER=google) ---
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-1.5-flash
EMBEDDING_MODEL=models/embedding-001

# --- Hugging Face (only if LLM_PROVIDER=huggingface) ---
# Gated models (e.g. meta-llama/*) need: (1) access approved on huggingface.co
# (2) a read token: https://huggingface.co/settings/tokens
HF_MODEL=microsoft/DialoGPT-small
HF_TOKEN=
HF_TEMPERATURE=0.7

# --- OpenRouter (only if LLM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Vector Store Selection: "faiss" | "chroma" | "both" ---
VECTOR_STORE_TYPE=chroma

# --- Paths ---
PDF_PATH=data/handbook.pdf
FAISS_INDEX_PATH=vectorstore/faiss_index
CHROMA_PERSIST_DIR=vectorstore/chroma_db

# --- Chunking ---
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# --- RAG Retrieval ---
RETRIEVER_K=6                      # top-k chunks to retrieve

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
